CREATE TABLE PRESCRIBER (
    PrescriberID INT PRIMARY KEY,
    PrescriberName VARCHAR(50) NOT NULL,
    LicenseNumber INT UNIQUE NOT NULL,
    ContactInfo BIGINT,
    DigitalSignature VARCHAR(10) NOT NULL
);

INSERT INTO PRESCRIBER (PrescriberID, PrescriberName, LicenseNumber, ContactInfo, DigitalSignature)
